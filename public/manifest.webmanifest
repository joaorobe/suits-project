{
  "name": "Suits",
  "short_name": "Suits",
  "description": "Sistema de gestão Suits para aluguel, ajustes e medidas.",
  "id": "/",
  "start_url": "/login",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#0b2740",
